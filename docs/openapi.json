{
  "openapi": "3.1.0",
  "info": {
    "title": "Mnemic Agent Memory API",
    "version": "0.1.0",
    "description": "Local-first HTTP API for source-keyed, graph-backed long-term memory used by coding agents and LLM applications."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8088",
      "description": "Default local Mnemic backend"
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Runtime health checks"
    },
    {
      "name": "memory",
      "description": "Memory write, recall, relation, and explanation endpoints"
    },
    {
      "name": "context",
      "description": "Prompt-ready context and session briefing endpoints"
    },
    {
      "name": "governance",
      "description": "Policy and memory hygiene endpoints"
    },
    {
      "name": "events",
      "description": "Timeline, JSONL handoff, import, and rollback endpoints"
    }
  ],
  "paths": {
    "/actuator/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "getHealth",
        "summary": "Return backend health.",
        "responses": {
          "200": {
            "description": "Backend health.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/memories": {
      "get": {
        "tags": [
          "memory"
        ],
        "operationId": "searchMemories",
        "summary": "Recall memories with optional text and metadata filters.",
        "parameters": [
          {
            "$ref": "#/components/parameters/query"
          },
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/memoryType"
          },
          {
            "$ref": "#/components/parameters/tag"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching memories.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentMemoryRecord"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "memory"
        ],
        "operationId": "rememberMemory",
        "summary": "Create or update a source-keyed memory.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentMemoryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stored memory.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/memories/preview": {
      "post": {
        "tags": [
          "memory"
        ],
        "operationId": "previewMemoryWrite",
        "summary": "Dry-run a memory write without mutating state.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentMemoryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Write preview, diff, policy findings, and state summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryWritePreview"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/explain": {
      "get": {
        "tags": [
          "memory"
        ],
        "operationId": "explainRecall",
        "summary": "Explain why recall selected and ranked memories.",
        "parameters": [
          {
            "$ref": "#/components/parameters/query"
          },
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/memoryType"
          },
          {
            "$ref": "#/components/parameters/tag"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Recall explanation entries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRecallExplanation"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/memories/{memoryUid}": {
      "get": {
        "tags": [
          "memory"
        ],
        "operationId": "getMemory",
        "summary": "Fetch one memory by UID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/memoryUid"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory record.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRecord"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/memories/{memoryUid}/relations": {
      "post": {
        "tags": [
          "memory"
        ],
        "operationId": "linkMemories",
        "summary": "Attach an explicit relation from one memory to another.",
        "parameters": [
          {
            "$ref": "#/components/parameters/memoryUid"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentMemoryRelationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated source memory.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/context-pack": {
      "get": {
        "tags": [
          "context"
        ],
        "operationId": "getContextPack",
        "summary": "Build prompt-ready memory context for an agent task.",
        "parameters": [
          {
            "$ref": "#/components/parameters/query"
          },
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Context pack.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryContextPack"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/briefing": {
      "get": {
        "tags": [
          "context"
        ],
        "operationId": "getSessionBriefing",
        "summary": "Return recent, important, and problem memories for session start.",
        "parameters": [
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Session briefing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryBriefing"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/stats": {
      "get": {
        "tags": [
          "governance"
        ],
        "operationId": "getMemoryStats",
        "summary": "Return memory coverage and maintenance stats.",
        "responses": {
          "200": {
            "description": "Memory stats.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryStats"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/policy": {
      "get": {
        "tags": [
          "governance"
        ],
        "operationId": "getPolicyStatus",
        "summary": "Return the active resolved governance policy and source.",
        "responses": {
          "200": {
            "description": "Resolved policy status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryPolicyStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/audit": {
      "get": {
        "tags": [
          "governance"
        ],
        "operationId": "auditMemories",
        "summary": "Return memory hygiene findings and health score.",
        "parameters": [
          {
            "$ref": "#/components/parameters/project"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory audit.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryAudit"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/timeline": {
      "get": {
        "tags": [
          "events"
        ],
        "operationId": "getMemoryTimeline",
        "summary": "Return recent append-only memory events.",
        "parameters": [
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/memoryType"
          },
          {
            "$ref": "#/components/parameters/tag"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory event timeline.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryTimeline"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/export": {
      "get": {
        "tags": [
          "events"
        ],
        "operationId": "exportMemoryJsonl",
        "summary": "Export memory events as JSONL for audit or handoff.",
        "parameters": [
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/memoryType"
          },
          {
            "$ref": "#/components/parameters/tag"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "JSONL export envelope.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryJsonlExport"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-memory/snapshot": {
      "get": {
        "tags": [
          "events"
        ],
        "operationId": "getMemorySnapshot",
        "summary": "Reconstruct memory graph state by replaying event log up to an optional timestamp.",
        "parameters": [
          {
            "$ref": "#/components/parameters/project"
          },
          {
            "$ref": "#/components/parameters/memoryType"
          },
          {
            "$ref": "#/components/parameters/tag"
          },
          {
            "$ref": "#/components/parameters/asOf"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Historical memory graph snapshot.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemorySnapshot"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/import": {
      "post": {
        "tags": [
          "events"
        ],
        "operationId": "importMemoryJsonl",
        "summary": "Preview or import exported memory-event JSONL.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentMemoryJsonlImportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryJsonlImportResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/rollback-preview": {
      "get": {
        "tags": [
          "events"
        ],
        "operationId": "previewRollback",
        "summary": "Preview the state effect of rolling back one event.",
        "parameters": [
          {
            "$ref": "#/components/parameters/eventUid"
          }
        ],
        "responses": {
          "200": {
            "description": "Rollback preview.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRollbackPreview"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/agent-memory/rollback": {
      "post": {
        "tags": [
          "events"
        ],
        "operationId": "rollbackMemoryEvent",
        "summary": "Apply a policy-gated rollback for the latest event.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentMemoryRollbackRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Applied rollback result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMemoryRollbackResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "query": {
        "name": "query",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Text query for lexical and graph recall."
      },
      "project": {
        "name": "project",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Repo or product scope."
      },
      "memoryType": {
        "name": "memoryType",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Memory category filter."
      },
      "tag": {
        "name": "tag",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Tag filter."
      },
      "asOf": {
        "name": "asOf",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time"
        },
        "description": "Temporal filter. Recall endpoints return memories whose validFrom/validTo window includes this timestamp; event endpoints return events at or before this timestamp."
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Maximum result count."
      },
      "memoryUid": {
        "name": "memoryUid",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Memory entity UID, such as AgentMemory-1."
      },
      "eventUid": {
        "name": "eventUid",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Memory event UID, such as MemoryEvent-1."
      }
    },
    "responses": {
      "Error": {
        "description": "Structured error response.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthStatus": {
        "type": "object",
        "required": [
          "status",
          "service"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "UP"
          },
          "service": {
            "type": "string",
            "example": "mnemic-server"
          }
        }
      },
      "JsonObject": {
        "type": "object",
        "additionalProperties": true
      },
      "AgentMemoryRequest": {
        "type": "object",
        "required": [
          "title",
          "content"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "memoryType": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string"
          },
          "sourceKey": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "importance": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "observedAt": {
            "type": "string",
            "format": "date-time"
          },
          "validFrom": {
            "type": "string",
            "format": "date-time"
          },
          "validTo": {
            "type": "string",
            "format": "date-time"
          },
          "relatedMemoryUids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/JsonObject"
          }
        }
      },
      "AgentMemoryRecord": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AgentMemoryRequest"
          },
          {
            "type": "object",
            "required": [
              "entityUid",
              "title",
              "content",
              "memoryType",
              "project",
              "tags",
              "source",
              "sourceKey",
              "actor",
              "importance",
              "confidence",
              "observedAt",
              "validFrom",
              "validTo",
              "createdAt",
              "updatedAt",
              "metadata",
              "relatedMemoryUids"
            ],
            "properties": {
              "entityUid": {
                "type": "string"
              },
              "memoryType": {
                "type": "string"
              },
              "project": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "source": {
                "type": "string"
              },
              "sourceKey": {
                "type": "string"
              },
              "actor": {
                "type": "string"
              },
              "importance": {
                "type": "number"
              },
              "confidence": {
                "type": "number"
              },
              "observedAt": {
                "type": "string"
              },
              "validFrom": {
                "type": "string"
              },
              "validTo": {
                "type": "string"
              },
              "createdAt": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              },
              "metadata": {
                "$ref": "#/components/schemas/JsonObject"
              },
              "relatedMemoryUids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "policyFindings": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AgentMemoryPolicyFinding"
                }
              }
            }
          }
        ]
      },
      "AgentMemoryRelationRequest": {
        "type": "object",
        "required": [
          "targetMemoryUid"
        ],
        "properties": {
          "targetMemoryUid": {
            "type": "string"
          },
          "relationshipType": {
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/JsonObject"
          }
        }
      },
      "AgentMemoryPolicyFinding": {
        "type": "object",
        "required": [
          "policyId",
          "severity",
          "field",
          "message",
          "recommendation"
        ],
        "properties": {
          "policyId": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "block"
            ]
          },
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      },
      "AgentMemoryPolicyStatus": {
        "type": "object",
        "required": [
          "generatedAt",
          "source",
          "config"
        ],
        "properties": {
          "generatedAt": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "required": [
              "kind",
              "policyFile"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "default",
                  "file",
                  "constructor"
                ]
              },
              "policyFile": {
                "type": "string"
              }
            }
          },
          "config": {
            "$ref": "#/components/schemas/JsonObject"
          }
        }
      },
      "AgentMemoryEventDiff": {
        "type": "object",
        "required": [
          "subject",
          "before",
          "after",
          "changedFields"
        ],
        "properties": {
          "subject": {
            "type": "string",
            "enum": [
              "memory",
              "relation",
              "state",
              "none"
            ]
          },
          "before": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/JsonObject"
              },
              {
                "type": "null"
              }
            ]
          },
          "after": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/JsonObject"
              },
              {
                "type": "null"
              }
            ]
          },
          "changedFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AgentMemoryStateSummary": {
        "type": "object",
        "required": [
          "memoryCount",
          "relationCount",
          "eventCount",
          "memories",
          "relations"
        ],
        "properties": {
          "memoryCount": {
            "type": "integer"
          },
          "relationCount": {
            "type": "integer"
          },
          "eventCount": {
            "type": "integer"
          },
          "memories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentMemoryRecord"
            }
          },
          "relations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentMemoryRelation"
            }
          }
        }
      },
      "AgentMemoryRelation": {
        "type": "object",
        "required": [
          "sourceMemoryUid",
          "targetMemoryUid",
          "relationshipType",
          "attributes",
          "createdAt"
        ],
        "properties": {
          "sourceMemoryUid": {
            "type": "string"
          },
          "targetMemoryUid": {
            "type": "string"
          },
          "relationshipType": {
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/JsonObject"
          },
          "createdAt": {
            "type": "string"
          }
        }
      },
      "AgentMemoryWritePreview": {
        "type": "object",
        "required": [
          "generatedAt",
          "dryRun",
          "action",
          "eventType",
          "wouldAppendEventUid",
          "memoryUid",
