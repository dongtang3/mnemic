FROM node:24-alpine AS build

WORKDIR /app
COPY package*.json ./
COPY mnemic-sdk/package*.json ./mnemic-sdk/
COPY mnemic-cli/package*.json ./mnemic-cli/
COPY mnemic-server/package*.json ./mnemic-server/
COPY mcp-server/package*.json ./mcp-server/
COPY studio/package*.json ./studio/
RUN npm install
COPY mnemic-sdk/tsconfig.json ./mnemic-sdk/tsconfig.json
COPY mnemic-sdk/src ./mnemic-sdk/src
COPY mnemic-server/tsconfig.json ./mnemic-server/tsconfig.json
COPY mnemic-server/src ./mnemic-server/src
RUN npm --prefix mnemic-server run build
RUN npm prune --omit=dev

FROM node:24-alpine

WORKDIR /app
ENV SERVER_PORT=8088
ENV MNEMIC_STORE=json
ENV MNEMIC_MEMORY_FILE=/data/mnemic-memory.json
ENV MNEMIC_SQLITE_FILE=/data/mnemic-memory.sqlite
COPY --from=build /app/package*.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/mnemic-sdk/package*.json ./mnemic-sdk/
COPY --from=build /app/mnemic-sdk/dist ./mnemic-sdk/dist
COPY --from=build /app/mnemic-server/package*.json ./mnemic-server/
COPY --from=build /app/mnemic-server/dist ./mnemic-server/dist
RUN mkdir -p /data
EXPOSE 8088
HEALTHCHECK --interval=10s --timeout=5s --retries=12 --start-period=10s CMD node -e "fetch('http://127.0.0.1:8088/actuator/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
CMD ["node", "mnemic-server/dist/server.js"]
