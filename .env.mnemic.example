SERVER_PORT=8088
MNEMIC_PORT=8088
MNEMIC_STORE=json
MNEMIC_MEMORY_FILE=target/mnemic-memory.json
MNEMIC_SQLITE_FILE=target/mnemic-memory.sqlite
MNEMIC_API_BASE=http://localhost:8088
# Optional: copy .mnemic/policy.example.json to .mnemic/policy.json, then set this path.
# MNEMIC_POLICY_FILE=.mnemic/policy.json

# Set MNEMIC_STORE=sqlite for a local SQLite-backed memory store.

# Optional future graph-store settings.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mnemic-memory-dev-password
NEO4J_AUTH=neo4j/mnemic-memory-dev-password
