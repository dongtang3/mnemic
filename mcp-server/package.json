{
  "name": "@mnemic/memory-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server that exposes Mnemic long-term agent memory tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongtang3/mnemic.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/dongtang3/mnemic/issues"
  },
  "homepage": "https://github.com/dongtang3/mnemic/tree/main/mcp-server#readme",
  "keywords": [
    "agent-memory",
    "mcp",
    "model-context-protocol",
    "mnemic",
    "llm"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "mnemic-memory-mcp": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "npm --prefix ../mnemic-sdk run build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/*.mjs"
  },
  "dependencies": {
    "@mnemic/sdk": "file:../mnemic-sdk",
    "@modelcontextprotocol/sdk": "^1.23.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
